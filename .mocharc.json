    "diff": true,
    "extension": ["ts"],
    "package": "./package.json",
    "reporter": "spec",
    "slow": "75",
    "timeout": "7000",
    "ui": "bdd",
    "watch-files": ["lib/**/*.js", "test/**/*.js"],
    "watch-ignore": ["lib/vendor"],
